---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import TechnologiesSection from "../components/TechnologiesSection.astro";
import EducationSection from "../components/EducationSection.astro";
---

<Layout
  title="Angel Spinazzola – Full Stack Developer"
  description="Portfolio profesional de Angel Spinazzola, desarrollador full stack especializado en ASP.NET, React, SQL Server y desarrollo de aplicaciones modernas."
>
  <div id="app-window" class="flex h-screen flex-col overflow-hidden bg-zinc-50 dark:bg-zinc-950">

    <!-- Title Bar -->
    <div id="title-bar" class="relative flex h-9 shrink-0 select-none items-center border-b border-zinc-200 bg-zinc-100 dark:border-zinc-800 dark:bg-zinc-900">
      <div class="flex flex-1 items-center gap-2.5 px-4">
        <div class="h-2.5 w-2.5 rounded-full bg-emerald-500"></div>
      </div>

      <!-- Título dinámico centrado -->
      <span id="window-title" class="pointer-events-none absolute left-1/2 -translate-x-1/2 text-xs font-medium text-zinc-400 dark:text-zinc-500"></span>

      <!-- Terminal button -->
      <button
        id="terminal-btn"
        class="flex h-full w-10 items-center justify-center text-zinc-400 transition-colors hover:bg-zinc-200 hover:text-zinc-700 dark:hover:bg-zinc-800 dark:hover:text-zinc-300"
        aria-label="Abrir terminal"
        title="Terminal (Ctrl+5)"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="2,4 6,7 2,10" />
          <line x1="7" y1="10" x2="12" y2="10" />
        </svg>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="flex h-full w-10 items-center justify-center text-zinc-400 transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-800"
        aria-label="Cambiar tema"
      >
        <svg class="hidden h-3.5 w-3.5 dark:block" fill="currentColor" viewBox="0 0 20 20">
          <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
        </svg>
        <svg class="block h-3.5 w-3.5 dark:hidden" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
        </svg>
      </button>

      <!-- Window controls -->
      <div class="flex h-full shrink-0">
        <button class="flex h-full w-11 items-center justify-center text-zinc-400 transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-800" aria-label="Minimizar">
          <svg width="10" height="1" viewBox="0 0 10 1" fill="currentColor"><rect width="10" height="1" /></svg>
        </button>
        <button id="maximize-btn" class="flex h-full w-11 items-center justify-center text-zinc-400 transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-800" aria-label="Maximizar">
          <svg id="icon-maximize" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1"><rect x="0.5" y="0.5" width="9" height="9" /></svg>
          <svg id="icon-restore" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1" class="hidden">
            <rect x="2.5" y="0.5" width="7" height="7" />
            <rect x="0.5" y="2.5" width="7" height="7" fill="var(--restore-fill)" />
          </svg>
        </button>
        <button id="close-btn" class="flex h-full w-11 items-center justify-center text-zinc-400 transition-colors hover:bg-red-500 hover:text-white dark:hover:bg-red-600" aria-label="Cerrar">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line x1="0" y1="0" x2="10" y2="10" />
            <line x1="10" y1="0" x2="0" y2="10" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Tab Bar -->
    <div class="tab-bar flex shrink-0 border-b border-zinc-200 bg-zinc-100 dark:border-zinc-800 dark:bg-zinc-900">
      <button class="tab" data-tab="home">Inicio</button>
      <button class="tab" data-tab="projects">Proyectos</button>
      <button class="tab" data-tab="stack">Stack</button>
      <button class="tab" data-tab="education">Educación</button>
    </div>

    <!-- Content Area -->
    <div class="relative flex-1 overflow-hidden">

      <div id="tab-home" class="tab-panel overflow-auto">
        <HeroSection />
      </div>

      <div id="tab-projects" class="tab-panel overflow-auto">
        <ProjectsSection />
      </div>

      <div id="tab-stack" class="tab-panel overflow-auto">
        <TechnologiesSection />
      </div>

      <div id="tab-education" class="tab-panel overflow-auto">
        <EducationSection />
      </div>

    </div>
  </div>

  <!-- Terminal Easter Egg -->
  <div id="terminal-overlay" class="terminal-overlay" role="dialog" aria-label="Terminal">
    <div class="terminal-window">
      <div class="terminal-titlebar">
        <div class="flex items-center gap-1.5">
          <button id="terminal-close-dot" class="h-3 w-3 rounded-full bg-red-500 transition-opacity hover:opacity-80"></button>
          <span class="h-3 w-3 rounded-full bg-yellow-500 opacity-30"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-500 opacity-30"></span>
        </div>
        <span class="terminal-titlebar-name">bash — angel@portfolio</span>
        <span class="w-16"></span>
      </div>
      <div id="terminal-output" class="terminal-output"></div>
      <div class="terminal-input-row">
        <span class="terminal-prompt">angel@portfolio:~$&nbsp;</span>
        <input id="terminal-input" type="text" class="terminal-input" autocomplete="off" spellcheck="false" />
      </div>
    </div>
  </div>

  <!-- Close Overlay -->
  <div id="close-overlay" class="close-overlay">
    <div class="flex flex-col items-center gap-10 px-6 text-center">
      <div class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-emerald-600 dark:text-emerald-400">portfolio.exe</p>
        <h2 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-white md:text-5xl">¿Ya te vas?</h2>
        <p class="text-base text-zinc-500 dark:text-zinc-400">Antes de cerrar, podés contactarme.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="https://www.linkedin.com/in/angel-spinazzola/"
          target="_blank"
          rel="noopener noreferrer"
          class="overlay-btn"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/AngelSpinazzola"
          target="_blank"
          rel="noopener noreferrer"
          class="overlay-btn"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="/cv-angel-spinazzola.pdf"
          download="CV-Angel-Spinazzola.pdf"
          class="overlay-btn-primary"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          Descargar CV
        </a>
      </div>

      <button id="back-btn" class="inline-flex items-center gap-2 text-sm text-zinc-400 transition-colors hover:text-zinc-600 dark:hover:text-zinc-200">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al portfolio
      </button>
    </div>
  </div>

</Layout>

<style>
  .tab {
    @apply relative flex h-9 flex-1 cursor-pointer items-center justify-center border-r border-zinc-200 px-5 text-sm text-zinc-500 transition-colors duration-150 hover:bg-zinc-200/60 sm:flex-none sm:justify-start dark:border-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-800/50;
    white-space: nowrap;
  }

  .tab.active {
    @apply bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100;
  }

  .tab.active::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background-color: #10b981;
  }

  .tab-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow-y: auto;
  }

  @media (min-width: 768px) {
    .tab-panel {
      overflow-y: scroll;
      scrollbar-gutter: stable;
    }
  }

  .tab-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Fondo grid lines + glow global */
  .tab-panel {
    background-image:
      radial-gradient(ellipse 70% 40% at 50% 0%, rgba(16, 185, 129, 0.1), transparent),
      linear-gradient(rgba(161, 161, 170, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(161, 161, 170, 0.12) 1px, transparent 1px);
    background-size: auto, 40px 40px, 40px 40px;
  }

  :global(.dark) .tab-panel {
    background-image:
      radial-gradient(ellipse 70% 40% at 50% 0%, rgba(16, 185, 129, 0.08), transparent),
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: auto, 40px 40px, 40px 40px;
  }

  /* Alinear desde arriba */
  #tab-home,
  #tab-projects,
  #tab-stack,
  #tab-education {
    justify-content: flex-start;
  }

  /* Modo ventana flotante */
  #app-window {
    transition: border-radius 0.3s ease, box-shadow 0.3s ease;
  }

  #app-window.windowed {
    position: fixed;
    border-radius: 0.75rem;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  #title-bar.is-draggable {
    cursor: grab;
  }

  #title-bar.is-dragging {
    cursor: grabbing;
  }

  body.show-desktop {
    background-color: #18181b;
    background-image: radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  :global(.dark) #icon-restore rect:last-child {
    fill: #09090b;
  }

  #icon-restore rect:last-child {
    fill: #f4f4f5;
  }

  /* Close overlay */
  .close-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(9, 9, 11, 0.97);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  :global(.light) .close-overlay {
    background-color: rgba(250, 250, 250, 0.97);
  }

  .close-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-btn {
    @apply inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-all duration-200 hover:border-zinc-500 hover:text-white;
  }

  .overlay-btn-primary {
    @apply inline-flex items-center gap-2 rounded-lg border border-emerald-500/50 bg-emerald-500/10 px-5 py-2.5 text-sm font-medium text-emerald-400 transition-all duration-200 hover:border-emerald-500 hover:bg-emerald-500/20;
  }

  /* ── Terminal ── */
  .terminal-overlay {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .terminal-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .terminal-window {
    width: min(680px, 92vw);
    display: flex;
    flex-direction: column;
    background: #0c0c0c;
    border: 1px solid #27272a;
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.8);
    transform: translateY(10px) scale(0.97);
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .terminal-overlay.visible .terminal-window {
    transform: translateY(0) scale(1);
  }

  .terminal-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    background: #111;
    border-bottom: 1px solid #1c1c1c;
    user-select: none;
  }

  .terminal-titlebar-name {
    font-size: 0.7rem;
    color: #3f3f46;
    font-family: ui-monospace, monospace;
  }

  .terminal-output {
    padding: 1rem;
    font-family: ui-monospace, 'Cascadia Code', monospace;
    font-size: 0.8rem;
    line-height: 1.65;
    color: #a1a1aa;
    min-height: 180px;
    max-height: 52vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #27272a transparent;
  }

  .terminal-input-row {
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem 0.65rem;
    border-top: 1px solid #1c1c1c;
  }

  .terminal-prompt {
    color: #10b981;
    font-family: ui-monospace, monospace;
    font-size: 0.8rem;
    white-space: nowrap;
    user-select: none;
  }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #e4e4e7;
    font-family: ui-monospace, monospace;
    font-size: 0.8rem;
    caret-color: #10b981;
  }

  /* Scrollbar de los paneles */
  .tab-panel {
    scrollbar-width: thin;
    scrollbar-color: rgba(161, 161, 170, 0.25) transparent;
  }
  .tab-panel::-webkit-scrollbar {
    width: 4px;
  }
  .tab-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .tab-panel::-webkit-scrollbar-thumb {
    background: rgba(161, 161, 170, 0.25);
    border-radius: 2px;
  }
  .tab-panel::-webkit-scrollbar-thumb:hover {
    background: rgba(52, 211, 153, 0.5);
  }

  /* Ocultar scrollbar en tab bar (mobile) */
  .tab-bar {
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .tab-bar::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    const saved = localStorage.getItem("theme");
    const theme = saved || "dark";
    if (theme === "dark") document.documentElement.classList.add("dark");
  })();

  const visited = new Set();

  function triggerAnimations(panel) {
    if (visited.has(panel.id)) return;
    visited.add(panel.id);

    const elements = panel.querySelectorAll(".animate-on-scroll");
    elements.forEach(function (el, i) {
      setTimeout(function () {
        el.classList.add("animate-fade-in-up");
        el.classList.remove("opacity-0");
      }, i * 60);
    });
  }

  var tabLabels = { home: "Inicio", projects: "Proyectos", stack: "Stack", education: "Educación" };

  function activateTab(tabId) {
    const tabs = document.querySelectorAll(".tab");
    const panels = document.querySelectorAll(".tab-panel");

    tabs.forEach(function (t) { t.classList.remove("active"); });
    panels.forEach(function (p) { p.classList.remove("active"); });

    const tab = document.querySelector('[data-tab="' + tabId + '"]');
    const panel = document.getElementById("tab-" + tabId);

    if (tab) tab.classList.add("active");
    if (panel) {
      panel.classList.add("active");
      triggerAnimations(panel);
    }

    const titleEl = document.getElementById("window-title");
    if (titleEl) titleEl.textContent = "Angel Spinazzola — " + (tabLabels[tabId] || "");
  }

  function initWindow() {
    activateTab("home");

    document.querySelectorAll(".tab").forEach(function (tab) {
      tab.addEventListener("click", function () {
        activateTab(tab.dataset.tab);
      });
    });

    const toggle = document.getElementById("theme-toggle");
    if (toggle) {
      toggle.addEventListener("click", function () {
        document.documentElement.classList.toggle("dark");
        const next = document.documentElement.classList.contains("dark") ? "dark" : "light";
        localStorage.setItem("theme", next);
      });
    }

    // Maximize toggle + drag
    const maximizeBtn = document.getElementById("maximize-btn");
    const appWindow   = document.getElementById("app-window");
    const titleBar    = document.getElementById("title-bar");
    const iconMaximize = document.getElementById("icon-maximize");
    const iconRestore  = document.getElementById("icon-restore");
    let isWindowed = false;

    function enterWindowed() {
      const m = 24;
      appWindow.style.left   = m + "px";
      appWindow.style.top    = m + "px";
      appWindow.style.width  = (window.innerWidth  - m * 2) + "px";
      appWindow.style.height = (window.innerHeight - m * 2) + "px";
      appWindow.classList.add("windowed");
      document.body.classList.add("show-desktop");
      iconMaximize.classList.add("hidden");
      iconRestore.classList.remove("hidden");
      titleBar.classList.add("is-draggable");
      isWindowed = true;
    }

    function exitWindowed() {
      appWindow.classList.remove("windowed");
      appWindow.style.left = appWindow.style.top = "";
      appWindow.style.width = appWindow.style.height = "";
      document.body.classList.remove("show-desktop");
      iconMaximize.classList.remove("hidden");
      iconRestore.classList.add("hidden");
      titleBar.classList.remove("is-draggable", "is-dragging");
      isWindowed = false;
    }

    if (maximizeBtn) {
      maximizeBtn.addEventListener("click", function () {
        if (isWindowed) exitWindowed(); else enterWindowed();
      });
    }

    // Doble-click en title bar → toggle windowed
    titleBar.addEventListener("dblclick", function (e) {
      if (e.target.closest("button")) return;
      if (isWindowed) exitWindowed(); else enterWindowed();
    });

    // Drag
    let dragging = false, ox = 0, oy = 0;

    titleBar.addEventListener("mousedown", function (e) {
      if (!isWindowed || e.target.closest("button")) return;
      dragging = true;
      const r = appWindow.getBoundingClientRect();
      ox = e.clientX - r.left;
      oy = e.clientY - r.top;
      titleBar.classList.add("is-dragging");
      e.preventDefault();
    });

    document.addEventListener("mousemove", function (e) {
      if (!dragging) return;
      const maxX = window.innerWidth  - appWindow.offsetWidth;
      const maxY = window.innerHeight - 36;
      const x = Math.max(0, Math.min(e.clientX - ox, maxX));
      const y = Math.max(0, Math.min(e.clientY - oy, maxY));
      appWindow.style.left = x + "px";
      appWindow.style.top  = y + "px";
    });

    document.addEventListener("mouseup", function () {
      if (!dragging) return;
      dragging = false;
      titleBar.classList.remove("is-dragging");
    });

    // ── Keyboard shortcuts ──
    var tabOrder = ["home", "projects", "stack", "education"];

    document.addEventListener("keydown", function (e) {
      // Ctrl+1-4 → cambiar pestaña
      if (e.ctrlKey && !e.shiftKey && !e.altKey && e.key >= "1" && e.key <= "4") {
        var idx = parseInt(e.key) - 1;
        if (tabOrder[idx]) { e.preventDefault(); activateTab(tabOrder[idx]); }
      }
      // Ctrl+5 → terminal
      if (e.ctrlKey && e.key === "5") {
        e.preventDefault();
        if (terminalOpen) closeTerminal(); else openTerminal();
      }
    });

    // ── Terminal ──
    var terminalOpen = false;
    var cmdHistory = [], histIdx = -1;

    function esc(s) {
      return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
    }

    function termAppend(html) {
      var out = document.getElementById("terminal-output");
      (Array.isArray(html) ? html : [html]).forEach(function (line) {
        var d = document.createElement("div");
        d.innerHTML = line === "" ? "&nbsp;" : line;
        out.appendChild(d);
      });
      out.scrollTop = out.scrollHeight;
    }

    var CMDS = {
      help: function () {
        termAppend([
          '<span style="color:#10b981">Comandos disponibles:</span>',
          '  <span style="color:#e4e4e7">whoami</span>          — info sobre el dev',
          '  <span style="color:#e4e4e7">ls</span>              — listar secciones',
          '  <span style="color:#e4e4e7">cat about.txt</span>   — sobre mí',
          '  <span style="color:#e4e4e7">cat skills.txt</span>  — stack técnico',
          '  <span style="color:#e4e4e7">cd &lt;sección&gt;</span>    — navegar (inicio · proyectos · stack · educacion)',
          '  <span style="color:#e4e4e7">clear</span>           — limpiar terminal',
          '  <span style="color:#e4e4e7">exit</span>            — cerrar terminal',
          "",
        ]);
      },
      whoami: function () {
        termAppend([
          '<span style="color:#10b981">Angel Spinazzola</span>',
          'Full Stack Developer · Buenos Aires, Argentina',
          'Stack: C# · .NET · React · TypeScript · SQL',
          "",
        ]);
      },
      ls: function () {
        termAppend([
          '<span style="color:#10b981">inicio/</span>  <span style="color:#10b981">proyectos/</span>  <span style="color:#10b981">stack/</span>  <span style="color:#10b981">educacion/</span>',
          "",
        ]);
      },
      "cat about.txt": function () {
        termAppend([
          "Soy desarrollador Full Stack apasionado por construir",
          "aplicaciones web modernas y funcionales.",
          "",
          "Me especializo en el ecosistema .NET para backend",
          "y React + TypeScript para frontend.",
          "",
        ]);
      },
      "cat skills.txt": function () {
        termAppend([
          '<span style="color:#10b981">Backend:</span>   C# · .NET · MySQL · PostgreSQL · SQL Server',
          '<span style="color:#10b981">Frontend:</span>  React · TypeScript · JavaScript · Tailwind · Astro',
          '<span style="color:#10b981">DevOps:</span>    Docker · GitHub',
          "",
        ]);
      },
      clear: function () {
        document.getElementById("terminal-output").innerHTML = "";
      },
      exit: function () { closeTerminal(); },
      quit: function () { closeTerminal(); },
    };

    function runCmd(raw) {
      var cmd = raw.trim();
      termAppend('<span style="color:#10b981">angel@portfolio:~$</span>&nbsp;' + esc(cmd));
      if (!cmd) return;

      if (cmd.toLowerCase().startsWith("cd ")) {
        var map = { inicio:"home", proyectos:"projects", stack:"stack", educacion:"education" };
        var dest = map[cmd.slice(3).trim().toLowerCase()];
        if (dest) { activateTab(dest); closeTerminal(); }
        else termAppend('<span style="color:#f87171">cd: ' + esc(cmd.slice(3).trim()) + ': No such directory</span>');
        return;
      }

      var handler = CMDS[cmd.toLowerCase()];
      if (handler) handler();
      else termAppend('<span style="color:#f87171">bash: ' + esc(cmd) + ': command not found</span>');
    }

    function openTerminal() {
      var overlay = document.getElementById("terminal-overlay");
      var out = document.getElementById("terminal-output");
      if (!terminalOpen) {
        out.innerHTML = "";
        termAppend([
          '<span style="color:#10b981">Portfolio Terminal</span> <span style="color:#3f3f46">— Ctrl+5 para cerrar</span>',
          '<span style="color:#52525b">Escribí <span style="color:#a1a1aa">help</span> para ver los comandos.</span>',
          "",
        ]);
      }
      overlay.classList.add("visible");
      terminalOpen = true;
      setTimeout(function () { document.getElementById("terminal-input").focus(); }, 50);
    }

    function closeTerminal() {
      document.getElementById("terminal-overlay").classList.remove("visible");
      terminalOpen = false;
    }

    var termInput = document.getElementById("terminal-input");
    if (termInput) {
      termInput.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
          var val = termInput.value;
          cmdHistory.unshift(val);
          histIdx = -1;
          termInput.value = "";
          runCmd(val);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          if (histIdx < cmdHistory.length - 1) termInput.value = cmdHistory[++histIdx];
        } else if (e.key === "ArrowDown") {
          e.preventDefault();
          if (histIdx > 0) termInput.value = cmdHistory[--histIdx];
          else { histIdx = -1; termInput.value = ""; }
        } else if (e.key === "Escape") {
          closeTerminal();
        }
      });
    }

    var termBtn = document.getElementById("terminal-btn");
    if (termBtn) termBtn.addEventListener("click", function () {
      if (terminalOpen) closeTerminal(); else openTerminal();
    });

    var termCloseDot = document.getElementById("terminal-close-dot");
    if (termCloseDot) termCloseDot.addEventListener("click", closeTerminal);

    document.getElementById("terminal-overlay").addEventListener("click", function (e) {
      if (e.target === this) closeTerminal();
    });

    // Close overlay
    const closeBtn = document.getElementById("close-btn");
    const closeOverlay = document.getElementById("close-overlay");
    const backBtn = document.getElementById("back-btn");

    if (closeBtn) {
      closeBtn.addEventListener("click", function () {
        closeOverlay.classList.add("visible");
      });
    }

    if (backBtn) {
      backBtn.addEventListener("click", function () {
        closeOverlay.classList.remove("visible");
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initWindow);
  } else {
    initWindow();
  }
</script>
