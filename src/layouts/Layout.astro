---
import "@fontsource/bebas-neue/400.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";

const { title, description } = Astro.props;
const siteUrl = "https://angelspinazzola.dev";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Angel Spinazzola",
  "jobTitle": "Full Stack Developer",
  "url": siteUrl,
  "sameAs": [
    "https://github.com/AngelSpinazzola",
    "https://www.linkedin.com/in/angel-spinazzola/"
  ]
});
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="author" content="Angel Spinazzola" />
    <meta name="robots" content="index, follow" />

    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </head>

  <body class="h-full bg-zinc-50 text-zinc-900 antialiased dark:text-zinc-100" style="background-color: #05080f;">
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Manrope', system-ui, sans-serif;
  }

  .opacity-0 {
    opacity: 0;
  }

  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', system-ui, sans-serif !important;
    font-weight: 400 !important;
    letter-spacing: 0.15em;
  }

</style>
