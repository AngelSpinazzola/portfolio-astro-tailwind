---
import { Image } from "astro:assets";
import heroImage from "../assets/images/angel.png";
---

<section id="home" class="px-6 pb-12 pt-32 lg:pb-16 lg:pt-56">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:justify-center lg:gap-32">

        <!-- Foto -->
        <div class="order-1 shrink-0 lg:order-2">
          <div class="relative">
            <div class="absolute -inset-2 rounded-full ring-yellow-300/15 blur-lg"></div>
            <Image
              src={heroImage}
              alt="Angel Spinazzola"
              width={320}
              height={320}
              format="webp"
              loading="eager"
              fetchpriority="high"
              class="relative h-44 w-44 rounded-full object-cover ring-2 ring-yellow-300/50 lg:h-56 lg:w-56"
            />
          </div>
        </div>

        <!-- Contenido -->
        <div class="order-2 space-y-6 text-center lg:order-1 lg:text-left">
          <div class="space-y-2">
            <h1 class="text-4xl font-bold text-zinc-900 md:text-6xl dark:text-white"
            style="letter-spacing: 0.02em">
              Angel Spinazzola
            </h1>
            <div class="relative h-9 md:h-12">
              <h2 id="rotating-title" class="absolute left-0 right-0 whitespace-nowrap text-2xl font-semibold text-emerald-600 md:text-4xl dark:text-yellow-300"
              style="font-family: 'Manrope', sans-serif; letter-spacing: 0.01em; transition: opacity 0.35s ease, filter 0.35s ease;">
                Desarrollador Full-Stack
              </h2>
            </div>
          </div>

          <!-- Bio -->
          <p class="max-w-md text-sm leading-relaxed text-zinc-500 dark:text-zinc-300 lg:mt-4">
            Trabajo con una mentalidad orientada a procesos: entender el problema, diseñar la solución
            y construir software claro, escalable y mantenible. Creo firmemente en el
            <span class="font-medium text-emerald-600 dark:text-yellow-300">aprendizaje continuo</span>
            como la clave para evolucionar como desarrollador.
          </p>

          <!-- Links -->
          <div class="flex flex-wrap items-center justify-center gap-2 lg:justify-start">
            <a
              href="https://www.linkedin.com/in/angel-spinazzola/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn de Angel Spinazzola"
              class="social-btn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>

            <a
              href="https://github.com/AngelSpinazzola"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub de Angel Spinazzola"
              class="social-btn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>

            <a
              href="/cv-angel-spinazzola.pdf"
              download="CV-Angel-Spinazzola.pdf"
              class="cv-btn"
              id="cv-download-btn"
            >
              <span class="cv-btn-content">
                <span class="cv-btn-text">Descargar CV</span>
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" />
                </svg>
              </span>
              <span class="cv-progress-bar"></span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .social-btn {
    @apply inline-flex items-center gap-2 rounded-lg border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-600 transition-all duration-200 hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-800 dark:text-zinc-400 dark:hover:border-zinc-700 dark:hover:text-zinc-100;
  }

  .cv-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    padding: 0.5rem 1.1rem;
    background-color: transparent;
    color: #fde047;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 6px;
    border: 1.5px solid rgba(253, 224, 71, 0.5);
    transition: border-color 0.2s ease, color 0.2s ease;
    cursor: pointer;
  }

  .cv-btn:hover {
    border-color: #fde047;
  }

  .cv-btn-content {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cv-btn-content svg {
    transition: transform 0.25s ease;
  }

  .cv-btn:hover .cv-btn-content svg {
    transform: translateY(2px);
  }

  .cv-progress-bar {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background-color: #fde047;
    z-index: 0;
    transition: none;
  }

  .cv-btn.loading {
    color: #080c14;
    border-color: #fde047;
  }

  .cv-btn.loading .cv-progress-bar {
    width: 100%;
    transition: width 1.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

</style>

<script is:inline>
  // ── CV download progress ──
  var cvBtn = document.getElementById("cv-download-btn");
  var cvBtnText = cvBtn.querySelector(".cv-btn-text");
  cvBtn.addEventListener("click", function () {
    if (cvBtn.classList.contains("loading")) return;
    cvBtnText.textContent = "Descargando CV";
    cvBtn.classList.add("loading");
    setTimeout(function () {
      cvBtnText.textContent = "Descargado ✓";
      cvBtn.classList.add("done");
      setTimeout(function () {
        cvBtnText.textContent = "Descargar CV";
        cvBtn.classList.remove("loading", "done");
        cvBtn.querySelector(".cv-progress-bar").style.transition = "none";
        setTimeout(function () {
          cvBtn.querySelector(".cv-progress-bar").style.transition = "";
        }, 50);
      }, 1200);
    }, 1900);
  });

  var titles = ["Desarrollador Full-Stack", "Técnico Universitario en Programación"];
  var current = 0;
  var el = document.getElementById("rotating-title");

  setInterval(function () {
    el.style.opacity = "0";
    el.style.filter = "blur(8px)";
    setTimeout(function () {
      current = (current + 1) % titles.length;
      el.textContent = titles[current];
      el.style.opacity = "1";
      el.style.filter = "blur(0px)";
    }, 380);
  }, 3000);
</script>
