---
import { Image } from "astro:assets";
import heroImage from "../assets/images/angel.png";
---

<section id="home" class="px-6 pb-12 pt-32 lg:pb-16 lg:pt-56">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col items-center gap-12 lg:flex-row lg:items-center lg:justify-center lg:gap-32">

        <!-- Foto -->
        <div class="order-1 shrink-0 lg:order-2">
          <div class="relative">
            <div class="absolute -inset-2 rounded-full bg-emerald-500/15 blur-lg"></div>
            <Image
              src={heroImage}
              alt="Angel Spinazzola"
              width={320}
              height={320}
              format="webp"
              loading="eager"
              fetchpriority="high"
              class="relative h-44 w-44 rounded-full object-cover ring-2 ring-emerald-500/25 lg:h-56 lg:w-56"
            />
          </div>
        </div>

        <!-- Contenido -->
        <div class="order-2 space-y-6 text-center lg:order-1 lg:text-left">
          <div class="space-y-2">
            <h1 class="text-4xl font-bold tracking-tight text-zinc-900 md:text-5xl dark:text-white">
              Angel Spinazzola
            </h1>
            <h2 class="text-2xl font-semibold text-emerald-600 md:text-3xl dark:text-emerald-400">
              Desarrollador Full-Stack
            </h2>
            <p class="text-base text-zinc-500 dark:text-zinc-400">
              Técnico Universitario en Programación · UTN
            </p>
          </div>

          <!-- Bio -->
          <p class="max-w-md text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Trabajo con una mentalidad orientada a procesos: entender el problema, diseñar la solución
            y construir software claro, escalable y mantenible. Creo firmemente en el
            <span class="font-medium text-emerald-600 dark:text-emerald-400">aprendizaje continuo</span>
            como la clave para evolucionar como desarrollador.
          </p>

          <!-- Links -->
          <div class="flex flex-wrap items-center justify-center gap-2 lg:justify-start">
            <a
              href="https://www.linkedin.com/in/angel-spinazzola/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn de Angel Spinazzola"
              class="social-btn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>

            <a
              href="https://github.com/AngelSpinazzola"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub de Angel Spinazzola"
              class="social-btn"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>

            <a
              href="/cv-angel-spinazzola.pdf"
              download="CV-Angel-Spinazzola.pdf"
              class="social-btn-primary"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Descargar CV
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .social-btn {
    @apply inline-flex items-center gap-2 rounded-lg border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-600 transition-all duration-200 hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-800 dark:text-zinc-400 dark:hover:border-zinc-700 dark:hover:text-zinc-100;
  }

  .social-btn-primary {
    @apply inline-flex items-center gap-2 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-700 transition-all duration-200 hover:border-emerald-500/60 hover:bg-emerald-500/20 dark:border-emerald-500/30 dark:bg-emerald-500/10 dark:text-emerald-400 dark:hover:border-emerald-500/50 dark:hover:bg-emerald-500/20;
  }
</style>
