---
import { Image } from "astro:assets";
import { technologies } from "../data/technologies";
---

<section id="technologies" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-5xl">

      <!-- Header -->
      <div class="animate-on-scroll mb-14 opacity-0">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
          Herramientas
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          Stack tecnológico
        </h2>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7">
        {technologies.map((tech, i) => (
          <div
            class="animate-on-scroll tech-card group flex flex-col items-center gap-2.5 rounded-xl border border-zinc-200 p-4 opacity-0 transition-all duration-200 hover:border-emerald-500/40 hover:bg-zinc-50 dark:border-zinc-800 dark:hover:border-emerald-500/30 dark:hover:bg-zinc-900/60"
            style={`animation-delay: ${i * 35}ms`}
          >
            <Image
              src={tech.icon}
              alt={tech.name}
              width={40}
              height={40}
              class="h-8 w-8 transition-transform duration-200 group-hover:scale-110"
            />
            <span class="text-center text-xs font-medium text-zinc-500 dark:text-zinc-500">
              {tech.name}
            </span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
