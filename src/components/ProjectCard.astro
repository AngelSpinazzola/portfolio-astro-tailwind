---
import { Image } from "astro:assets";
import type { Project } from "../data/projects";
import { techIcons } from "../data/techIcons";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
---

<article
  class="animate-on-scroll project-row group opacity-0"
  style={`animation-delay: ${index * 100}ms`}
>
  <!-- Contenido (izquierda en desktop, abajo en mobile) -->
  <div class="content-side">
    <div class="space-y-3">
      <span class="text-[10px] font-semibold uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
        {project.label}
      </span>
      <h3 class="text-xl font-semibold leading-snug text-zinc-900 dark:text-zinc-100">
        {project.title}
      </h3>
      <p
        class="text-sm leading-relaxed text-zinc-900 dark:text-zinc-400"
        set:html={project.description}
      />
    </div>

    <!-- Stack -->
    <div class="flex flex-wrap gap-1.5 pt-1">
      {project.tags.map((tag) => (
        <span class="inline-flex items-center gap-1 rounded-md bg-zinc-100 px-2 py-0.5 text-[11px] font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
          {techIcons[tag.name] && (
            <Image
              src={techIcons[tag.name]}
              alt=""
              width={12}
              height={12}
              loading="lazy"
              class="h-3 w-3 opacity-60 dark:invert"
            />
          )}
          {tag.name}
        </span>
      ))}
    </div>

    <!-- Acciones -->
    <div class="flex gap-2 pt-2">
      {project.demoUrl && (
        <a
          href={project.demoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-3 py-1.5 text-xs font-medium text-emerald-700 transition-all duration-200 hover:border-emerald-500/60 hover:bg-emerald-500/20 dark:border-emerald-500/30 dark:bg-emerald-500/5 dark:text-emerald-400 dark:hover:border-emerald-500/50 dark:hover:bg-emerald-500/10"
        >
          Ver Demo ↗
        </a>
      )}
      {project.githubUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-1.5 text-xs font-medium text-zinc-500 transition-all duration-200 hover:border-zinc-300 hover:text-zinc-700 dark:border-zinc-800 dark:text-zinc-500 dark:hover:border-zinc-700 dark:hover:text-zinc-300"
        >
          <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          Código
        </a>
      )}
    </div>
  </div>

  <!-- Imagen (derecha en desktop, arriba en mobile) -->
  <div class="image-side">
    {project.image ? (
      <Image
        src={project.image}
        alt={project.title}
        width={800}
        height={450}
        format="webp"
        quality={88}
        loading={index < 2 ? "eager" : "lazy"}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
        sizes="(max-width: 768px) 100vw, 55vw"
      />
    ) : (
      <div class={`h-full w-full bg-gradient-to-br ${project.gradient}`} />
    )}
  </div>
</article>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid theme('colors.zinc.200');
    transition: opacity 0.5s ease;
  }

  :global(.dark) .project-row {
    border-bottom-color: theme('colors.zinc.800');
  }

  .project-row:last-child {
    border-bottom: none;
  }

  .content-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    order: 2;
  }

  .image-side {
    order: 1;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background-color: theme('colors.zinc.100');
  }

  :global(.dark) .image-side {
    background-color: theme('colors.zinc.800');
  }

  /* Desktop: lado a lado */
  @media (min-width: 768px) {
    .project-row {
      grid-template-columns: 1fr 1.4fr;
      align-items: center;
      gap: 3rem;
      padding: 2.5rem 0;
    }

    .content-side {
      order: 1;
    }

    .image-side {
      order: 2;
    }
  }
</style>
