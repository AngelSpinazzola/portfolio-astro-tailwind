---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
---

<section id="projects" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-5xl">

      <!-- Header -->
      <div class="animate-on-scroll mb-14 opacity-0">
        <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-emerald-600 dark:text-emerald-400">
          Trabajo
        </p>
        <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          Proyectos
        </h2>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        {projects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>

      <!-- Ver más -->
      <div class="animate-on-scroll mt-10 opacity-0">
        <a
          href="https://github.com/AngelSpinazzola?tab=repositories"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-zinc-400 transition-colors duration-200 hover:text-zinc-700 dark:text-zinc-500 dark:hover:text-zinc-300"
        >
          Ver más en GitHub
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
