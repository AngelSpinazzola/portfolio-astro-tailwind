---
import { Image } from "astro:assets";
import { technologies, techCategories } from "../data/technologies";
---

<section id="technologies" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-6xl">

      <div class="animate-on-scroll mb-14 opacity-0">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
        style="letter-spacing: 0.02em;">
          Stack
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        {techCategories.map((category) => {
          const items = technologies.filter((t) => t.category === category);
          return (
            <div class="flex flex-col gap-2">
              <!-- Label -->
              <span class="text-sm font-semibold uppercase tracking-widest text-yellow-300 text-center">
                {category}
              </span>

              <!-- Container -->
              <div class="animate-on-scroll tech-container flex-1 opacity-0">
                <div class="spotlight"></div>

                <!-- Iconos -->
                <div class="grid grid-cols-4 gap-x-4 gap-y-6">
                {items.map((tech) => (
                  <div class="group flex flex-col items-center gap-2.5">
                    <Image
                      src={tech.icon}
                      alt={tech.name}
                      width={48}
                      height={48}
                      class="h-9 w-9 lg:h-12 lg:w-12 opacity-75 transition-all duration-200 group-hover:opacity-100 group-hover:scale-110"
                    />
                    <span class="text-[11px] font-medium text-gray-200 transition-colors duration-200 group-hover:text-zinc-300">
                      {tech.name}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          );
        })}
      </div>

    </div>
  </div>
</section>

<style>
  .tech-container {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.75rem;
    transition: border-color 0.3s ease;
  }

  .tech-container:hover {
    border-color: rgba(253, 224, 71, 0.15);
  }

  .spotlight {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(253, 224, 71, 0.18) 0%, transparent 70%);
    pointer-events: none;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }
</style>

<script is:inline>
  document.querySelectorAll(".tech-container").forEach(function (container) {
    var spotlight = container.querySelector(".spotlight");

    container.addEventListener("mouseenter", function () {
      spotlight.style.opacity = "1";
    });

    container.addEventListener("mousemove", function (e) {
      var rect = container.getBoundingClientRect();
      var x = e.clientX - rect.left;
      var y = e.clientY - rect.top;
      spotlight.style.left = x + "px";
      spotlight.style.top = y + "px";
    });

    container.addEventListener("mouseleave", function () {
      spotlight.style.opacity = "0";
    });
  });
</script>
