---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import TechnologiesSection from "../components/TechnologiesSection.astro";
import EducationSection from "../components/EducationSection.astro";
---

<Layout
  title="Angel Spinazzola – Full Stack Developer"
  description="Portfolio profesional de Angel Spinazzola, desarrollador full stack especializado en ASP.NET, React, SQL Server y desarrollo de aplicaciones modernas."
>

  <!-- Background -->
  <div class="bg-fixed-layer" aria-hidden="true"></div>

  <!-- Navbar -->
  <header id="navbar" class="fixed top-0 z-50 w-full border-transparent bg-transparent backdrop-blur-none transition-all duration-300 hidden sm:block">
    <div class="mx-auto flex h-12 max-w-6xl items-center justify-end px-6 sm:h-16 sm:grid sm:grid-cols-3">

      <!-- Izquierda (vacío o logo futuro) -->
      <div class="hidden sm:block"></div>

      <!-- Centro: nav links desktop -->
      <nav class="hidden items-center justify-center gap-1 sm:flex">
        <a href="#inicio"    class="nav-link">Inicio</a>
        <a href="#proyectos" class="nav-link">Proyectos</a>
        <a href="#stack"     class="nav-link">Stack</a>
        <a href="#educacion" class="nav-link">Educación</a>
      </nav>

      <!-- Derecha: vacío en mobile -->
      <div class="flex items-center justify-end gap-2"></div>
    </div>

  </header>

  <!-- Burger flotante (mobile) -->
  <button id="mobile-menu-btn" class="burger-btn sm:hidden" aria-label="Menú" aria-expanded="false">
    <span class="burger-line"></span>
    <span class="burger-line"></span>
    <span class="burger-line"></span>
  </button>

  <!-- Mobile nav overlay (fuera del header para cubrir toda la pantalla) -->
  <div id="mobile-nav" class="mobile-nav-overlay">
    <!-- Close -->
    <button id="mobile-close-btn" class="mobile-close" aria-label="Cerrar menú">✕</button>

    <!-- Links -->
    <nav class="flex flex-col justify-center flex-1 px-10 gap-2">
      <a href="#inicio"    class="mobile-nav-link" data-index="01">Inicio</a>
      <a href="#proyectos" class="mobile-nav-link" data-index="02">Proyectos</a>
      <a href="#stack"     class="mobile-nav-link" data-index="03">Stack</a>
      <a href="#educacion" class="mobile-nav-link" data-index="04">Educación</a>
    </nav>

    <!-- Redes sociales abajo -->
    <div class="flex gap-6 px-10 pb-12">
      <a href="https://github.com/AngelSpinazzola" target="_blank" class="mobile-social">GitHub</a>
      <a href="https://www.linkedin.com/in/angel-spinazzola/" target="_blank" class="mobile-social">LinkedIn</a>
    </div>
  </div>

  <!-- Sections -->
  <main>
    <div id="inicio">
      <HeroSection />
    </div>
    <div id="proyectos">
      <ProjectsSection />
    </div>
    <div id="stack">
      <TechnologiesSection />
    </div>
    <div id="educacion">
      <EducationSection />
    </div>
  </main>


</Layout>

<style>
  /* ── Background ── */
  .bg-fixed-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 55% at 15% 20%, rgba(14, 40, 100, 0.55) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 85% 75%, rgba(8, 25, 70, 0.4) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 70% 10%, rgba(20, 60, 130, 0.2) 0%, transparent 55%);
  }

  /* ── Navbar scroll ── */
  #navbar.navbar-visible {
    background-color: rgb(250 250 250 / 0.9);
    border-color: rgb(228 228 231 / 0.8);
    backdrop-filter: blur(12px);
  }

  :global(.dark) #navbar.navbar-visible {
    background-color: rgb(9 9 11 / 0.9);
    border-color: rgb(39 39 42 / 0.8);
  }

  /* ── Navbar ── */
  .nav-link {
    position: relative;
    padding: 0.25rem 0.75rem;
    font-size: 0.9375rem;
    color: #71717a;
    transition: color 0.2s;
    overflow: hidden;
  }

  .nav-link::before,
  .nav-link::after {
    content: '[';
    position: absolute;
    top: 50%;
    transform: translateY(-50%) translateX(-6px);
    opacity: 0;
    color: #fde047;
    font-size: 0.85rem;
    transition: transform 0.2s ease 0.12s, opacity 0.2s ease 0.12s;
  }

  .nav-link::after {
    content: ']';
    left: auto;
    right: 0;
    transform: translateY(-50%) translateX(6px);
  }

  .nav-link::before { left: 0; }

  .nav-link:hover {
    color: #a1a1aa;
  }

  .nav-link.active {
    color: #fde047;
  }

  .nav-link.active::before,
  .nav-link.active::after {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: #a1a1aa;
    transition: background-color 0.15s, color 0.15s;
  }

  .nav-icon-btn:hover {
    background-color: #f4f4f5;
    color: #18181b;
  }

  :global(.dark) .nav-icon-btn:hover {
    background-color: #27272a;
    color: #f4f4f5;
  }

  /* ── Burger flotante ── */
  .burger-btn {
    display: none;
    position: fixed;
    top: 0.75rem;
    right: 1rem;
    z-index: 300;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    cursor: pointer;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  @media (max-width: 639px) {
    .burger-btn { display: flex; }
  }

  .burger-line {
    display: block;
    width: 20px;
    height: 2px;
    background-color: #ffffff;
    border-radius: 2px;
    transition: opacity 0.2s ease;
  }

  .burger-btn.open {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Mobile nav overlay ── */
  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: #05080f;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 639px) {
    .mobile-nav-overlay { display: flex; }
  }

  .mobile-nav-overlay.open {
    transform: translateX(0);
  }

  .mobile-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 1.25rem;
    color: #ffffff;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    transition: color 0.15s;
    cursor: pointer;
  }

  .mobile-close:hover { color: #fff; }

  .mobile-nav-link {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.5rem;
    letter-spacing: 0.08em;
    color: rgba(255, 253, 253, 0.863);
    transition: color 0.2s ease;
    line-height: 1.1;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: #ffffff;
  }

  .mobile-social {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #e6d439;
    transition: color 0.2s;
  }

  .mobile-social:hover { color: #fde047; }

  /* Offset del navbar para el scroll */
  #inicio, #proyectos, #stack, #educacion {
    scroll-margin-top: 3rem;
  }

</style>

<script is:inline>
  // ── Tema (forzado dark temporalmente) ──
  document.documentElement.classList.add("dark");

  // ── Animaciones on scroll ──
  const observed = new Set();

  function triggerAnimations(root) {
    root.querySelectorAll(".animate-on-scroll").forEach(function (el) {
      if (observed.has(el)) return;
      observed.add(el);
      el.classList.add("animate-fade-in-up");
      el.classList.remove("opacity-0");
    });
  }

  const sectionObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) triggerAnimations(entry.target);
    });
  }, { threshold: 0.05 });

  document.querySelectorAll("#inicio, #proyectos, #stack, #educacion").forEach(function (s) {
    sectionObserver.observe(s);
  });

  // ── Nav active link ──
  var navLinks = document.querySelectorAll(".nav-link");
  var scrollingByClick = false;
  var scrollTimer;

  navLinks.forEach(function (link) {
    link.addEventListener("click", function () {
      navLinks.forEach(function (l) { l.classList.remove("active"); });
      link.classList.add("active");
      scrollingByClick = true;
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () { scrollingByClick = false; }, 1200);
    });
  });

  var linkObserver = new IntersectionObserver(function (entries) {
    if (scrollingByClick) return;
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      var id = entry.target.id;
      navLinks.forEach(function (l) {
        l.classList.toggle("active", l.getAttribute("href") === "#" + id);
      });
    });
  }, { threshold: 0, rootMargin: "-40% 0px -55% 0px" });

  document.querySelectorAll("#inicio, #proyectos, #stack, #educacion").forEach(function (s) {
    linkObserver.observe(s);
  });

  // ── Mobile menu ──
  var burgerBtn  = document.getElementById("mobile-menu-btn");
  var mobileNav  = document.getElementById("mobile-nav");

  function closeMobileNav() {
    mobileNav.classList.remove("open");
    burgerBtn.classList.remove("open");
    burgerBtn.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  burgerBtn.addEventListener("click", function () {
    var isOpen = mobileNav.classList.toggle("open");
    burgerBtn.classList.toggle("open", isOpen);
    burgerBtn.setAttribute("aria-expanded", isOpen);
    document.body.style.overflow = isOpen ? "hidden" : "";
  });

  var closeBtn = document.getElementById("mobile-close-btn");
  if (closeBtn) closeBtn.addEventListener("click", closeMobileNav);

  document.querySelectorAll(".mobile-nav-link").forEach(function (l) {
    l.addEventListener("click", closeMobileNav);
  });

  // ── Keyboard shortcuts ──
  var sectionIds = ["inicio", "proyectos", "stack", "educacion"];

  document.addEventListener("keydown", function (e) {
    if (e.ctrlKey && !e.shiftKey && !e.altKey && e.key >= "1" && e.key <= "4") {
      var el = document.getElementById(sectionIds[parseInt(e.key) - 1]);
      if (el) { e.preventDefault(); el.scrollIntoView({ behavior: "smooth" }); }
    }
  });

  // ── Navbar on scroll ──
  var navbar = document.getElementById("navbar");

  function updateNavbar() {
    if (window.scrollY > 20) {
      navbar.classList.add("navbar-visible");
    } else {
      navbar.classList.remove("navbar-visible");
    }
  }

  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();
</script>
