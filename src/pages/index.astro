---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import TechnologiesSection from "../components/TechnologiesSection.astro";
import EducationSection from "../components/EducationSection.astro";
---

<Layout
  title="Angel Spinazzola – Full Stack Developer"
  description="Portfolio profesional de Angel Spinazzola, desarrollador full stack especializado en ASP.NET, React, SQL Server y desarrollo de aplicaciones modernas."
>

  <!-- Background -->
  <div class="bg-fixed-layer" aria-hidden="true"></div>

  <!-- Navbar -->
  <header id="navbar" class="fixed top-0 z-50 w-full  border-transparent bg-transparent backdrop-blur-none transition-all duration-300">
    <div class="mx-auto flex h-12 max-w-6xl items-center justify-end px-6 sm:h-16 sm:grid sm:grid-cols-3">

      <!-- Izquierda (vacío o logo futuro) -->
      <div class="hidden sm:block"></div>

      <!-- Centro: nav links desktop -->
      <nav class="hidden items-center justify-center gap-1 sm:flex">
        <a href="#inicio"    class="nav-link">Inicio</a>
        <a href="#proyectos" class="nav-link">Proyectos</a>
        <a href="#stack"     class="nav-link">Stack</a>
        <a href="#educacion" class="nav-link">Educación</a>
      </nav>

      <!-- Derecha: acciones -->
      <div class="flex items-center justify-end gap-2">
        <!-- Theme toggle -->
        <button id="theme-toggle" class="nav-icon-btn" aria-label="Cambiar tema">
          <svg class="hidden h-3.5 w-3.5 dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
          </svg>
          <svg class="block h-3.5 w-3.5 dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
          </svg>
        </button>

        <!-- Burger (mobile) -->
        <button id="mobile-menu-btn" class="burger-btn sm:hidden" aria-label="Menú" aria-expanded="false">
          <span class="burger-line"></span>
          <span class="burger-line"></span>
          <span class="burger-line"></span>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-nav" class="mobile-nav-panel sm:hidden">
      <div class="flex flex-col px-6 py-2">
        <a href="#inicio"    class="mobile-nav-link">Inicio</a>
        <a href="#proyectos" class="mobile-nav-link">Proyectos</a>
        <a href="#stack"     class="mobile-nav-link">Stack</a>
        <a href="#educacion" class="mobile-nav-link">Educación</a>
      </div>
    </div>
  </header>

  <!-- Sections -->
  <main>
    <div id="inicio">
      <HeroSection />
    </div>
    <div id="proyectos">
      <ProjectsSection />
    </div>
    <div id="stack">
      <TechnologiesSection />
    </div>
    <div id="educacion">
      <EducationSection />
    </div>
  </main>


</Layout>

<style>
  /* ── Background ── */
  .bg-fixed-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 55% at 15% 20%, rgba(14, 40, 100, 0.55) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 85% 75%, rgba(8, 25, 70, 0.4) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 70% 10%, rgba(20, 60, 130, 0.2) 0%, transparent 55%);
  }

  /* ── Navbar scroll ── */
  #navbar.navbar-visible {
    background-color: rgb(250 250 250 / 0.9);
    border-color: rgb(228 228 231 / 0.8);
    backdrop-filter: blur(12px);
  }

  :global(.dark) #navbar.navbar-visible {
    background-color: rgb(9 9 11 / 0.9);
    border-color: rgb(39 39 42 / 0.8);
  }

  /* ── Navbar ── */
  .nav-link {
    position: relative;
    padding: 0.25rem 0.75rem;
    font-size: 0.9375rem;
    color: #71717a;
    transition: color 0.2s;
    overflow: hidden;
  }

  .nav-link::before,
  .nav-link::after {
    content: '[';
    position: absolute;
    top: 50%;
    transform: translateY(-50%) translateX(-6px);
    opacity: 0;
    color: #fde047;
    font-size: 0.85rem;
    transition: transform 0.2s ease 0.12s, opacity 0.2s ease 0.12s;
  }

  .nav-link::after {
    content: ']';
    left: auto;
    right: 0;
    transform: translateY(-50%) translateX(6px);
  }

  .nav-link::before { left: 0; }

  .nav-link:hover {
    color: #a1a1aa;
  }

  .nav-link.active {
    color: #fde047;
  }

  .nav-link.active::before,
  .nav-link.active::after {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  .nav-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: #a1a1aa;
    transition: background-color 0.15s, color 0.15s;
  }

  .nav-icon-btn:hover {
    background-color: #f4f4f5;
    color: #18181b;
  }

  :global(.dark) .nav-icon-btn:hover {
    background-color: #27272a;
    color: #f4f4f5;
  }

  /* ── Burger: solo visible en mobile ── */
  .burger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  @media (max-width: 639px) {
    .burger-btn { display: flex; }
  }

  .burger-btn:hover { background-color: #f4f4f5; }
  :global(.dark) .burger-btn:hover { background-color: #27272a; }

  .burger-line {
    display: block;
    width: 16px;
    height: 1.5px;
    background-color: #a1a1aa;
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .burger-btn.open .burger-line:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .burger-btn.open .burger-line:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger-btn.open .burger-line:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  /* ── Mobile nav panel: solo en mobile ── */
  .mobile-nav-panel {
    display: none;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (max-width: 639px) {
    .mobile-nav-panel { display: grid; }
  }

  .mobile-nav-panel.open {
    grid-template-rows: 1fr;
  }

  .mobile-nav-panel > div {
    overflow: hidden;
    border-top: 1px solid transparent;
    padding: 0.5rem 1.5rem 0.75rem;
    transition: border-color 0.28s ease;
  }

  .mobile-nav-panel.open > div {
    border-top-color: #e4e4e7;
  }

  :global(.dark) .mobile-nav-panel.open > div {
    border-top-color: #27272a;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #52525b;
    border-radius: 0.5rem;
    transition: color 0.15s, background-color 0.15s;
  }

  .mobile-nav-link::before {
    content: '';
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: #10b981;
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .mobile-nav-link:hover::before,
  .mobile-nav-link.active::before {
    opacity: 1;
  }

  .mobile-nav-link:hover {
    color: #18181b;
    background-color: #f4f4f5;
  }

  :global(.dark) .mobile-nav-link {
    color: #71717a;
  }

  :global(.dark) .mobile-nav-link:hover {
    color: #f4f4f5;
    background-color: #27272a;
  }

  /* Offset del navbar para el scroll */
  #inicio, #proyectos, #stack, #educacion {
    scroll-margin-top: 3rem;
  }

</style>

<script is:inline>
  // ── Tema ──
  (function () {
    const saved = localStorage.getItem("theme");
    const theme = saved || "dark";
    if (theme === "dark") document.documentElement.classList.add("dark");
  })();

  // ── Animaciones on scroll ──
  const observed = new Set();

  function triggerAnimations(root) {
    root.querySelectorAll(".animate-on-scroll").forEach(function (el) {
      if (observed.has(el)) return;
      observed.add(el);
      el.classList.add("animate-fade-in-up");
      el.classList.remove("opacity-0");
    });
  }

  const sectionObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) triggerAnimations(entry.target);
    });
  }, { threshold: 0.05 });

  document.querySelectorAll("#inicio, #proyectos, #stack, #educacion").forEach(function (s) {
    sectionObserver.observe(s);
  });

  // ── Nav active link ──
  var navLinks = document.querySelectorAll(".nav-link");
  var scrollingByClick = false;
  var scrollTimer;

  navLinks.forEach(function (link) {
    link.addEventListener("click", function () {
      navLinks.forEach(function (l) { l.classList.remove("active"); });
      link.classList.add("active");
      scrollingByClick = true;
      clearTimeout(scrollTimer);
      scrollTimer = setTimeout(function () { scrollingByClick = false; }, 1200);
    });
  });

  var linkObserver = new IntersectionObserver(function (entries) {
    if (scrollingByClick) return;
    entries.forEach(function (entry) {
      if (!entry.isIntersecting) return;
      var id = entry.target.id;
      navLinks.forEach(function (l) {
        l.classList.toggle("active", l.getAttribute("href") === "#" + id);
      });
    });
  }, { threshold: 0, rootMargin: "-40% 0px -55% 0px" });

  document.querySelectorAll("#inicio, #proyectos, #stack, #educacion").forEach(function (s) {
    linkObserver.observe(s);
  });

  // ── Theme toggle ──
  document.getElementById("theme-toggle").addEventListener("click", function () {
    document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
  });

  // ── Mobile menu ──
  var burgerBtn  = document.getElementById("mobile-menu-btn");
  var mobileNav  = document.getElementById("mobile-nav");

  burgerBtn.addEventListener("click", function () {
    var isOpen = mobileNav.classList.toggle("open");
    burgerBtn.classList.toggle("open", isOpen);
    burgerBtn.setAttribute("aria-expanded", isOpen);
  });

  document.querySelectorAll(".mobile-nav-link").forEach(function (l) {
    l.addEventListener("click", function () {
      mobileNav.classList.remove("open");
      burgerBtn.classList.remove("open");
      burgerBtn.setAttribute("aria-expanded", "false");
    });
  });

  // ── Keyboard shortcuts ──
  var sectionIds = ["inicio", "proyectos", "stack", "educacion"];

  document.addEventListener("keydown", function (e) {
    if (e.ctrlKey && !e.shiftKey && !e.altKey && e.key >= "1" && e.key <= "4") {
      var el = document.getElementById(sectionIds[parseInt(e.key) - 1]);
      if (el) { e.preventDefault(); el.scrollIntoView({ behavior: "smooth" }); }
    }
  });

  // ── Navbar on scroll ──
  var navbar = document.getElementById("navbar");

  function updateNavbar() {
    if (window.scrollY > 20) {
      navbar.classList.add("navbar-visible");
    } else {
      navbar.classList.remove("navbar-visible");
    }
  }

  window.addEventListener("scroll", updateNavbar, { passive: true });
  updateNavbar();
</script>
