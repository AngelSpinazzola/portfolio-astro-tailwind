---
import { Image } from "astro:assets";
import { technologies, techCategories } from "../data/technologies";
---

<section id="technologies" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-5xl">

      <div class="animate-on-scroll mb-14 opacity-0">
        <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
          Stack tecnológico
        </h2>
      </div>

      <div class="flex flex-col gap-10">
        {techCategories.map((category) => {
          const items = technologies.filter((t) => t.category === category);
          return (
            <div class="animate-on-scroll opacity-0">
              <!-- Divider con label -->
              <div class="mb-5 flex items-center gap-3">
                <span class="shrink-0 text-xs font-semibold uppercase tracking-widest text-emerald-500">
                  {category}
                </span>
                <div class="h-px flex-1 bg-zinc-200 dark:bg-zinc-800" />
              </div>

              <!-- Grid de cards -->
              <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7">
                {items.map((tech, i) => (
                  <div
                    class="tech-card group flex flex-col items-center gap-2.5 rounded-xl border border-zinc-200 bg-zinc-50 p-4 transition-all duration-200 hover:border-emerald-500/40 dark:border-zinc-800 dark:bg-zinc-900 dark:hover:border-emerald-500/30"
                    style={`animation-delay: ${i * 35}ms`}
                  >
                    <Image
                      src={tech.icon}
                      alt={tech.name}
                      width={40}
                      height={40}
                      class="h-8 w-8 transition-transform duration-200 group-hover:scale-110"
                    />
                    <span class="text-center text-xs font-medium text-zinc-500 dark:text-zinc-500">
                      {tech.name}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>

    </div>
  </div>
</section>
