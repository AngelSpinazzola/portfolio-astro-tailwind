---
import ProjectCard from "./ProjectCard.astro";
import { projects } from "../data/projects";
---

<section id="projects" class="py-24">
  <div class="container mx-auto px-6">
    <div class="mx-auto max-w-6xl">

      <!-- Header -->
      <div class="animate-on-scroll mb-14 opacity-0">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100"
        style="letter-spacing: 0.02em;">
          Proyectos
        </h2>
      </div>

      <!-- Proyectos -->
      <div>
        {projects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>

      <!-- Ver más -->
      <div class="animate-on-scroll mt-14 flex justify-center opacity-0">
        <a
          href="https://github.com/AngelSpinazzola?tab=repositories"
          target="_blank"
          rel="noopener noreferrer"
          class="github-more-btn group"
        >
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          <span>Ver más proyectos</span>
          <svg class="h-3 w-3 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .github-more-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    border-radius: 8px;
    border: none;
    background: linear-gradient(135deg, #0a0a0a, #4c1d95, #7c3aed, #ffffff22, #3b0764);
    background-size: 300% 300%;
    background-position: 0% 50%;
    animation: gradientMove 5s ease infinite;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  @keyframes gradientMove {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .github-more-btn:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      0 0 30px rgba(109, 40, 217, 0.5),
      0 0 60px rgba(109, 40, 217, 0.15);
  }

  .github-more-btn:active {
    transform: translateY(0) scale(1);
  }
</style>
